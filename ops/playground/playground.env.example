# Repo location for host-managed scripts and the ICP systemd unit.
PLAYGROUND_REPO_ROOT=/srv/automaton-launchpad/current

# Public hostnames and URLs.
PLAYGROUND_DOMAIN=playground.example.com
PLAYGROUND_RPC_DOMAIN=rpc.playground.example.com
PLAYGROUND_ACME_EMAIL=ops@example.com
PLAYGROUND_PUBLIC_RPC_URL=https://rpc.playground.example.com
INDEXER_CORS_ALLOWED_ORIGINS=https://playground.example.com

# Runtime images. Use the GitHub Actions image manifest to pin these to immutable digests.
PLAYGROUND_WEB_IMAGE=ghcr.io/example/automaton-playground-web:main
PLAYGROUND_INDEXER_IMAGE=ghcr.io/example/automaton-playground-indexer:main
PLAYGROUND_RPC_GATEWAY_IMAGE=ghcr.io/example/automaton-playground-rpc-gateway:main
PLAYGROUND_ANVIL_IMAGE=ghcr.io/foundry-rs/foundry:stable
PLAYGROUND_OTTERSCAN_IMAGE=otterscan/otterscan:latest
PLAYGROUND_GRAFANA_IMAGE=grafana/grafana-oss:11.6.0

# Local bind ports exposed only on loopback for host-managed Caddy and ops access.
PLAYGROUND_WEB_PORT=3000
PLAYGROUND_INDEXER_PORT=3001
PLAYGROUND_RPC_GATEWAY_PORT=3002
PLAYGROUND_OTTERSCAN_PORT=5100
PLAYGROUND_GRAFANA_PORT=3003
PLAYGROUND_LOCAL_REPLICA_PORT=8000
LOCAL_EVM_PORT=8545
LOCAL_EVM_RPC_URL=http://127.0.0.1:8545

# Shared operator-owned state. Keep these paths in one tree so host scripts and
# containers use the same files.
PLAYGROUND_STATE_DIR=/srv/automaton-playground/state
PLAYGROUND_SERVICE_DIR=/srv/automaton-playground/services
PLAYGROUND_RELEASES_DIR=/srv/automaton-playground/state/releases
PLAYGROUND_ARTIFACTS_DIR=/srv/automaton-playground/artifacts
PLAYGROUND_STATUS_FILE=/srv/automaton-playground/state/playground-status.json
PLAYGROUND_FACTORY_CANISTER_ID_FILE=/srv/automaton-playground/state/factory-canister-id.txt
LOCAL_EVM_DEPLOYMENT_FILE=/srv/automaton-playground/state/local-escrow-deployment.json
INDEXER_DB_PATH=/srv/automaton-playground/state/indexer.sqlite
PLAYGROUND_SMOKE_OUTPUT_FILE=/srv/automaton-playground/state/playground-smoke.json
PLAYGROUND_ICP_HOME=/srv/automaton-playground/icp-home
PLAYGROUND_ICP_STATE_DIR=/srv/automaton-playground/icp-state

# Bootstrap/reset contract. On the VPS, Compose owns anvil/web/indexer/rpc-gateway.
PLAYGROUND_MANAGE_SERVICES=0
PLAYGROUND_ANVIL_MANAGED=0
PLAYGROUND_REQUIRE_FORK=1
PLAYGROUND_ICP_NETWORK_NAME=local
PLAYGROUND_ICP_ENVIRONMENT=local
PLAYGROUND_FACTORY_CANISTER=factory

# Factory artifact inputs. CHILD_VERSION_COMMIT or PLAYGROUND_ENV_VERSION is required.
CHILD_WASM_PATH=/srv/automaton-playground/artifacts/child-automaton.wasm.gz
CHILD_VERSION_COMMIT=replace-with-ic-automaton-commit
PLAYGROUND_ENV_VERSION=replace-with-release-version

# The deploy script records each applied release manifest here.
# scripts/deploy-playground-release.sh writes both a timestamped copy and current.json.

# The containerized indexer waits for this file unless you inject the raw canister ID here.
INDEXER_FACTORY_CANISTER_ID=

# Playground chain metadata.
PLAYGROUND_ENV_LABEL=Automaton Playground
PLAYGROUND_CHAIN_ID=20260326
PLAYGROUND_CHAIN_NAME=Automaton Playground
PLAYGROUND_RESET_CADENCE_LABEL=Scheduled hard resets
PLAYGROUND_RESET_CADENCE_SECONDS=86400
PLAYGROUND_NATIVE_CURRENCY_NAME=Ether
PLAYGROUND_NATIVE_CURRENCY_SYMBOL=ETH
PLAYGROUND_NATIVE_CURRENCY_DECIMALS=18
PLAYGROUND_EXPLORER_URL=

# Base fork inputs for Anvil.
LOCAL_EVM_FORK_URL=https://base-mainnet.example.invalid/v2/replace-me
LOCAL_EVM_FORK_BLOCK_NUMBER=

# Faucet and RPC gateway policy.
PLAYGROUND_FAUCET_ENABLED=1
PLAYGROUND_FAUCET_ETH_AMOUNT=1
PLAYGROUND_FAUCET_USDC_AMOUNT=250
PLAYGROUND_FAUCET_CLAIM_WINDOW_SECONDS=86400
PLAYGROUND_FAUCET_MAX_CLAIMS_PER_WALLET=1
PLAYGROUND_FAUCET_MAX_CLAIMS_PER_IP=20
RPC_GATEWAY_BODY_LIMIT_BYTES=32768
RPC_GATEWAY_RATE_LIMIT_WINDOW_MS=60000
RPC_GATEWAY_RATE_LIMIT_MAX_REQUESTS=60

# Optional operator-only profiles.
# Otterscan stays loopback-only and points at localhost Anvil; use SSH tunnels if you enable it.
PLAYGROUND_OTTERSCAN_RPC_URL=http://127.0.0.1:8545
PLAYGROUND_GRAFANA_ADMIN_USER=admin
PLAYGROUND_GRAFANA_ADMIN_PASSWORD=change-me
